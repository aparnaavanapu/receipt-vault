# API Gateway base URL. The app sends POST requests to: <VITE_API_BASE_URL>/uploads
VITE_API_BASE_URL=https://your-api-id.execute-api.your-region.amazonaws.com/your-stage

# Amazon Cognito OIDC settings
VITE_COGNITO_AUTHORITY=https://cognito-idp.your-region.amazonaws.com/your_user_pool_id
VITE_COGNITO_CLIENT_ID=your_cognito_app_client_id
VITE_COGNITO_DOMAIN=https://your-cognito-domain.auth.your-region.amazoncognito.com
